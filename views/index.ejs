<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero-section">
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <div class="row align-items-center min-vh-100">
      <div class="col-lg-8 mx-auto text-center text-white">
        <h5 class="text-warning fw-light mb-3 animate-fade-in">★★★★★ PREMIUM HOTEL</h5>
        <h1 class="display-3 fw-bold mb-4 animate-fade-in">Welcome to<br><span class="text-warning">Hotel Oasis</span></h1>
        <p class="lead mb-4 animate-fade-in">Ideally located in the heart of Mumbai City, commercial capital of India. A perfect place for relaxation in luxury since 1985.</p>
        <div class="animate-fade-in">
          <a href="/rooms" class="btn btn-warning btn-lg px-5 me-3 rounded-pill shadow"><i class="bi bi-door-open me-2"></i>View Rooms</a>
          <a href="/contact" class="btn btn-outline-light btn-lg px-5 rounded-pill"><i class="bi bi-telephone me-2"></i>Contact Us</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="row g-4 text-center">
      <div class="col-md-3 col-6">
        <div class="feature-card p-4 bg-white rounded-4 shadow-sm h-100">
          <div class="feature-icon bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px">
            <i class="bi bi-wifi fs-2 text-warning"></i>
          </div>
          <h6 class="fw-bold">Free WiFi</h6>
          <p class="text-muted small mb-0">High-speed internet in all rooms</p>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="feature-card p-4 bg-white rounded-4 shadow-sm h-100">
          <div class="feature-icon bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px">
            <i class="bi bi-snow fs-2 text-warning"></i>
          </div>
          <h6 class="fw-bold">Air Conditioned</h6>
          <p class="text-muted small mb-0">32 A/C rooms available</p>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="feature-card p-4 bg-white rounded-4 shadow-sm h-100">
          <div class="feature-icon bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px">
            <i class="bi bi-tv fs-2 text-warning"></i>
          </div>
          <h6 class="fw-bold">Satellite TV</h6>
          <p class="text-muted small mb-0">Colour TV with satellite channels</p>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="feature-card p-4 bg-white rounded-4 shadow-sm h-100">
          <div class="feature-icon bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px">
            <i class="bi bi-clock fs-2 text-warning"></i>
          </div>
          <h6 class="fw-bold">24/7 Service</h6>
          <p class="text-muted small mb-0">Round the clock assistance</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- About Preview -->
<section class="py-5">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <div class="position-relative">
          <div class="about-img-placeholder rounded-4 shadow-lg" style="height:400px;background:linear-gradient(135deg,#c8a96e 0%,#8B6914 100%);display:flex;align-items:center;justify-content:center">
            <div class="text-center text-white">
              <i class="bi bi-building display-1 mb-3"></i>
              <h3>Since 1985</h3>
              <p>Over 38 Years of Excellence</p>
            </div>
          </div>
          <div class="position-absolute bottom-0 end-0 bg-warning text-dark p-3 rounded-3 shadow m-3">
            <h4 class="mb-0 fw-bold">32</h4>
            <small>Luxury Rooms</small>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <h6 class="text-warning fw-bold text-uppercase">About Our Hotel</h6>
        <h2 class="display-6 fw-bold mb-4">Experience Luxury & Comfort at <span class="text-warning">Hotel Oasis</span></h2>
        <p class="text-muted">Hotel Oasis founded in 1985, ideally located in the heart of Mumbai City, commercial capital of India. You'll find everything more than your expectations.</p>
        <p class="text-muted">All rooms are well designed with vibrant colours and furniture. A perfect place for relaxation in luxury. Hotel Oasis has evolved from time to time in its effort to cater to the growing needs of global and domestic travellers.</p>
        <div class="row g-3 mt-3 mb-4">
          <div class="col-6">
            <div class="d-flex align-items-center">
              <i class="bi bi-check-circle-fill text-warning me-2 fs-5"></i>
              <span>Free WiFi Internet</span>
            </div>
          </div>
          <div class="col-6">
            <div class="d-flex align-items-center">
              <i class="bi bi-check-circle-fill text-warning me-2 fs-5"></i>
              <span>Satellite Channels</span>
            </div>
          </div>
          <div class="col-6">
            <div class="d-flex align-items-center">
              <i class="bi bi-check-circle-fill text-warning me-2 fs-5"></i>
              <span>Intercom Facility</span>
            </div>
          </div>
          <div class="col-6">
            <div class="d-flex align-items-center">
              <i class="bi bi-check-circle-fill text-warning me-2 fs-5"></i>
              <span>Affordable Prices</span>
            </div>
          </div>
        </div>
        <a href="/about" class="btn btn-warning px-4 rounded-pill shadow-sm"><i class="bi bi-arrow-right me-2"></i>Learn More</a>
      </div>
    </div>
  </div>
</section>

<!-- Room Preview Section -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="text-center mb-5">
      <h6 class="text-warning fw-bold text-uppercase">Accommodation</h6>
      <h2 class="display-6 fw-bold">Our <span class="text-warning">Rooms & Suites</span></h2>
      <p class="text-muted mx-auto" style="max-width:600px">Choose from our range of well-designed rooms with vibrant colours and modern amenities</p>
    </div>
    <div class="row g-4">
      <% rooms.forEach(room => { %>
        <div class="col-lg-3 col-md-6">
          <div class="card room-card border-0 shadow-sm rounded-4 overflow-hidden h-100">
            <div class="room-card-img" style="height:200px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);display:flex;align-items:center;justify-content:center">
              <div class="text-center text-white">
                <i class="bi bi-door-open display-4"></i>
                <p class="mt-2 mb-0 fw-bold"><%= room.category %></p>
              </div>
            </div>
            <div class="card-body p-4">
              <h5 class="card-title fw-bold"><%= room.name %></h5>
              <p class="text-muted small mb-3"><%= room.description.substring(0, 80) %>...</p>
              <div class="d-flex flex-wrap gap-2 mb-3">
                <% room.amenities.split(',').slice(0, 3).forEach(amenity => { %>
                  <span class="badge bg-light text-dark border"><%= amenity.trim() %></span>
                <% }); %>
              </div>
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <span class="h5 text-warning fw-bold">₹<%= room.price.toLocaleString('en-IN') %></span>
                  <small class="text-muted">/night</small>
                </div>
                <a href="/rooms/<%= room.id %>" class="btn btn-outline-warning btn-sm rounded-pill px-3">View Details</a>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
    <div class="text-center mt-5">
      <a href="/rooms" class="btn btn-warning btn-lg px-5 rounded-pill shadow"><i class="bi bi-grid me-2"></i>View All Rooms</a>
    </div>
  </div>
</section>

<!-- Nearby Tourist Places -->
<section class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <h6 class="text-warning fw-bold text-uppercase">Explore Mumbai</h6>
      <h2 class="display-6 fw-bold">Nearby <span class="text-warning">Tourist Places</span></h2>
      <p class="text-muted mx-auto" style="max-width:600px">Hotel Oasis is surrounded with city attractions like famous landmarks, business hubs and tourist places</p>
    </div>
    <div class="row g-4">
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
          <div style="height:180px;background:linear-gradient(135deg,#e65c00 0%,#f9d423 100%);display:flex;align-items:center;justify-content:center">
            <i class="bi bi-bank display-3 text-white"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold"><i class="bi bi-geo-alt-fill text-warning me-2"></i>Gateway of India</h5>
            <p class="text-muted small">Built in 1924, this iconic 26-metre arch monument overlooks the Arabian Sea. Originally erected to commemorate the landing of King George V, it stands as Mumbai's most famous landmark and a symbol of the city's colonial heritage. Just 2 km from our hotel.</p>
            <span class="badge bg-warning bg-opacity-10 text-dark"><i class="bi bi-clock me-1"></i>~10 min drive</span>
          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
          <div style="height:180px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);display:flex;align-items:center;justify-content:center">
            <i class="bi bi-train-front display-3 text-white"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold"><i class="bi bi-geo-alt-fill text-warning me-2"></i>Chhatrapati Shivaji Terminus</h5>
            <p class="text-muted small">A UNESCO World Heritage Site built in 1888, this Victorian Gothic Revival railway station is an outstanding example of late 19th-century architecture. Its ornate stone dome, turrets, and stained-glass windows make it a marvel. Walking distance from our hotel.</p>
            <span class="badge bg-warning bg-opacity-10 text-dark"><i class="bi bi-clock me-1"></i>~5 min walk</span>
          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
          <div style="height:180px;background:linear-gradient(135deg,#11998e 0%,#38ef7d 100%);display:flex;align-items:center;justify-content:center">
            <i class="bi bi-water display-3 text-white"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold"><i class="bi bi-geo-alt-fill text-warning me-2"></i>Marine Drive</h5>
            <p class="text-muted small">Known as the Queen's Necklace, this 3.6 km arc-shaped promenade along the coastline of South Mumbai was built in 1920. The stretch of street lights along the road at night resembles a string of pearls, creating a stunning view of the Arabian Sea.</p>
            <span class="badge bg-warning bg-opacity-10 text-dark"><i class="bi bi-clock me-1"></i>~15 min drive</span>
          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
          <div style="height:180px;background:linear-gradient(135deg,#c94b4b 0%,#4b134f 100%);display:flex;align-items:center;justify-content:center">
            <i class="bi bi-building display-3 text-white"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold"><i class="bi bi-geo-alt-fill text-warning me-2"></i>Elephanta Caves</h5>
            <p class="text-muted small">A UNESCO World Heritage Site dating back to the 5th–8th century, these rock-cut caves on Elephanta Island house magnificent sculptures of Hindu deities, including the famous 20-foot Trimurti of Lord Shiva. Accessible by a ferry ride from the Gateway.</p>
            <span class="badge bg-warning bg-opacity-10 text-dark"><i class="bi bi-clock me-1"></i>~1 hr by ferry</span>
          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
          <div style="height:180px;background:linear-gradient(135deg,#f093fb 0%,#f5576c 100%);display:flex;align-items:center;justify-content:center">
            <i class="bi bi-shop display-3 text-white"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold"><i class="bi bi-geo-alt-fill text-warning me-2"></i>Crawford Market</h5>
            <p class="text-muted small">Officially renamed Mahatma Jyotiba Phule Mandai, this iconic market was built in 1869 during the British era. The Norman and Flemish architectural style features bas-relief panels designed by Rudyard Kipling's father. A bustling centre for fresh produce and goods.</p>
            <span class="badge bg-warning bg-opacity-10 text-dark"><i class="bi bi-clock me-1"></i>~5 min drive</span>
          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
          <div style="height:180px;background:linear-gradient(135deg,#2193b0 0%,#6dd5ed 100%);display:flex;align-items:center;justify-content:center">
            <i class="bi bi-tree display-3 text-white"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold"><i class="bi bi-geo-alt-fill text-warning me-2"></i>Horniman Circle Garden</h5>
            <p class="text-muted small">Established in 1872, this beautifully maintained garden sits within a stunning arc of heritage buildings in the Fort area. It features a large collection of trees and plants, and the surrounding Horniman Circle is one of Mumbai's finest examples of Victorian architecture.</p>
            <span class="badge bg-warning bg-opacity-10 text-dark"><i class="bi bi-clock me-1"></i>~3 min walk</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Testimonials / CTA -->
<section class="py-5 bg-dark text-white">
  <div class="container text-center">
    <h6 class="text-warning fw-bold text-uppercase">Book Your Stay</h6>
    <h2 class="display-6 fw-bold mb-4">Ready for an <span class="text-warning">Unforgettable</span> Experience?</h2>
    <p class="lead text-secondary mb-4 mx-auto" style="max-width:600px">Hotel Oasis is surrounded with city attractions like famous hospitals, business and tourist places. Book now and enjoy superb ambience with attentive, efficient and personalized services.</p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
      <a href="/rooms" class="btn btn-warning btn-lg px-5 rounded-pill shadow"><i class="bi bi-calendar-check me-2"></i>Book Now</a>
      <a href="tel:+912230227886" class="btn btn-outline-light btn-lg px-5 rounded-pill"><i class="bi bi-telephone me-2"></i>Call Us</a>
    </div>
  </div>
</section>

<%- include('partials/layout-end') %>
