<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <!-- Admin Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
    <div class="container-fluid px-4">
      <a class="navbar-brand" href="/admin/dashboard">
        <i class="bi bi-building text-warning me-2"></i>
        <span>Hotel <span class="text-warning">Oasis</span> Admin</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="adminNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/admin/dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/bookings"><i class="bi bi-calendar-check me-1"></i>Bookings</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/messages"><i class="bi bi-envelope me-1"></i>Messages
              <% if (typeof unreadMessages !== 'undefined' && unreadMessages > 0) { %>
                <span class="badge bg-danger rounded-pill"><%= unreadMessages %></span>
              <% } %>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/" target="_blank"><i class="bi bi-globe me-1"></i>View Site</a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-warning" href="/admin/logout"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="fw-bold mb-0">Dashboard</h2>
        <p class="text-muted mb-0">Welcome back, <span class="text-warning fw-bold"><%= adminName %></span></p>
      </div>
      <a href="/" class="btn btn-outline-warning rounded-pill" target="_blank"><i class="bi bi-globe me-1"></i>View Website</a>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
      <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 border-start border-warning border-4">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <p class="text-muted mb-1 small">Total Bookings</p>
                <h3 class="fw-bold mb-0"><%= stats.totalBookings %></h3>
              </div>
              <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px">
                <i class="bi bi-calendar-check text-warning fs-4"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 border-start border-success border-4">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <p class="text-muted mb-1 small">Total Revenue</p>
                <h3 class="fw-bold mb-0">₹<%= stats.totalRevenue.toLocaleString('en-IN') %></h3>
              </div>
              <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px">
                <i class="bi bi-currency-rupee text-success fs-4"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 border-start border-info border-4">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <p class="text-muted mb-1 small">Today's Bookings</p>
                <h3 class="fw-bold mb-0"><%= stats.todayBookings %></h3>
              </div>
              <div class="bg-info bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px">
                <i class="bi bi-clock text-info fs-4"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 border-start border-danger border-4">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <p class="text-muted mb-1 small">Pending Bookings</p>
                <h3 class="fw-bold mb-0"><%= stats.pendingBookings %></h3>
              </div>
              <div class="bg-danger bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px">
                <i class="bi bi-exclamation-circle text-danger fs-4"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <!-- Recent Bookings -->
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-header bg-white border-0 p-4">
            <div class="d-flex justify-content-between align-items-center">
              <h5 class="fw-bold mb-0"><i class="bi bi-calendar-check text-warning me-2"></i>Recent Bookings</h5>
              <a href="/admin/bookings" class="btn btn-outline-warning btn-sm rounded-pill">View All</a>
            </div>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead class="table-light">
                  <tr>
                    <th class="ps-4">ID</th>
                    <th>Guest</th>
                    <th>Room</th>
                    <th>Check-in</th>
                    <th>Amount</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (recentBookings.length === 0) { %>
                    <tr><td colspan="6" class="text-center py-4 text-muted">No bookings yet</td></tr>
                  <% } else { %>
                    <% recentBookings.forEach(booking => { %>
                      <tr>
                        <td class="ps-4 fw-bold">#<%= booking.id %></td>
                        <td><%= booking.guest_name %></td>
                        <td><%= booking.room_name %></td>
                        <td><%= booking.check_in %></td>
                        <td class="fw-bold">₹<%= booking.total_amount.toLocaleString('en-IN') %></td>
                        <td>
                          <span class="badge rounded-pill bg-<%= booking.payment_status === 'paid' ? 'success' : booking.payment_status === 'demo' ? 'info' : 'warning' %>">
                            <%= booking.payment_status %>
                          </span>
                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- Room Status -->
      <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-header bg-white border-0 p-4">
            <h5 class="fw-bold mb-0"><i class="bi bi-door-open text-warning me-2"></i>Room Status</h5>
          </div>
          <div class="card-body p-0">
            <div class="list-group list-group-flush">
              <% rooms.forEach(room => { %>
                <div class="list-group-item d-flex justify-content-between align-items-center px-4 py-3">
                  <div>
                    <h6 class="mb-0 fw-bold"><%= room.name %></h6>
                    <small class="text-muted">₹<%= room.price.toLocaleString('en-IN') %>/night</small>
                  </div>
                  <div class="d-flex gap-1">
                    <form action="/admin/rooms/<%= room.id %>/toggle" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-sm rounded-pill <%= room.available ? 'btn-success' : 'btn-danger' %>">
                        <%= room.available ? 'Available' : 'Unavailable' %>
                      </button>
                    </form>
                    <form action="/admin/rooms/<%= room.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this room?')">
                      <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill"><i class="bi bi-trash"></i></button>
                    </form>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Room Management & Gallery Management -->
    <div class="row g-4 mt-2">
      <!-- Add New Room -->
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-header bg-white border-0 p-4">
            <h5 class="fw-bold mb-0"><i class="bi bi-plus-circle text-warning me-2"></i>Add New Room</h5>
          </div>
          <div class="card-body p-4">
            <form action="/admin/rooms/add" method="POST">
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="room-name" class="form-label fw-bold">Room Name <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="room-name" name="name" placeholder="e.g. Deluxe A/C Double" required>
                </div>
                <div class="col-md-6">
                  <label for="room-category" class="form-label fw-bold">Category <span class="text-danger">*</span></label>
                  <select class="form-select" id="room-category" name="category" required>
                    <option value="">Select Category</option>
                    <option value="Economy">Economy</option>
                    <option value="Standard">Standard</option>
                    <option value="Deluxe">Deluxe</option>
                    <option value="Executive">Executive</option>
                  </select>
                </div>
                <div class="col-md-6">
                  <label for="room-type" class="form-label fw-bold">Type <span class="text-danger">*</span></label>
                  <select class="form-select" id="room-type" name="type" required>
                    <option value="">Select Type</option>
                    <option value="Single">Single</option>
                    <option value="Double">Double</option>
                    <option value="Triple">Triple</option>
                  </select>
                </div>
                <div class="col-md-6">
                  <label for="room-price" class="form-label fw-bold">Price per Night (₹) <span class="text-danger">*</span></label>
                  <input type="number" class="form-control" id="room-price" name="price" placeholder="e.g. 2500" min="1" required>
                </div>
                <div class="col-12">
                  <label for="room-description" class="form-label fw-bold">Description <span class="text-danger">*</span></label>
                  <textarea class="form-control" id="room-description" name="description" rows="2" placeholder="Room description..." required></textarea>
                </div>
                <div class="col-12">
                  <label for="room-amenities" class="form-label fw-bold">Amenities <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="room-amenities" name="amenities" placeholder="Free WiFi,A/C,Colour TV,Room Service" required>
                  <small class="text-muted">Comma-separated list of amenities</small>
                </div>
                <div class="col-12">
                  <button type="submit" class="btn btn-warning rounded-pill px-4"><i class="bi bi-plus-circle me-2"></i>Add Room</button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- Gallery Management -->
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-header bg-white border-0 p-4">
            <h5 class="fw-bold mb-0"><i class="bi bi-images text-warning me-2"></i>Gallery Management</h5>
          </div>
          <div class="card-body p-4">
            <form action="/admin/gallery/add" method="POST" class="mb-4">
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="gallery-title" class="form-label fw-bold">Title <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="gallery-title" name="title" placeholder="e.g. Hotel Lobby" required>
                </div>
                <div class="col-md-6">
                  <label for="gallery-category" class="form-label fw-bold">Category <span class="text-danger">*</span></label>
                  <select class="form-select" id="gallery-category" name="category" required>
                    <option value="">Select Category</option>
                    <option value="Interior">Interior</option>
                    <option value="Rooms">Rooms</option>
                    <option value="Dining">Dining</option>
                    <option value="Exterior">Exterior</option>
                    <option value="Facilities">Facilities</option>
                  </select>
                </div>
                <div class="col-12">
                  <label for="gallery-image" class="form-label fw-bold">Image URL <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="gallery-image" name="image" placeholder="/images/gallery-photo.jpg" required>
                </div>
                <div class="col-12">
                  <button type="submit" class="btn btn-warning rounded-pill px-4"><i class="bi bi-plus-circle me-2"></i>Add Photo</button>
                </div>
              </div>
            </form>
            <hr>
            <h6 class="fw-bold mb-3">Current Gallery (<%= gallery.length %> photos)</h6>
            <div class="list-group list-group-flush" style="max-height:250px;overflow-y:auto">
              <% if (gallery.length === 0) { %>
                <p class="text-muted text-center py-3">No gallery photos yet</p>
              <% } else { %>
                <% gallery.forEach(item => { %>
                  <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                    <div>
                      <h6 class="mb-0 small fw-bold"><%= item.title %></h6>
                      <small class="text-muted"><%= item.category %></small>
                    </div>
                    <form action="/admin/gallery/<%= item.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this gallery photo?')">
                      <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill"><i class="bi bi-trash"></i></button>
                    </form>
                  </div>
                <% }); %>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
